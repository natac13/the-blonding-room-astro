---
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'

export async function getStaticPaths() {
  const staffEntries = await getCollection('staff')
  return staffEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

interface Props {
  entry: CollectionEntry<'staff'>
}
const { entry } = Astro.props
const { Content } = await render(entry)

const roleDescription = entry.data.businessRole
  ? `${entry.data.role} & ${entry.data.businessRole}`
  : entry.data.role
const staffDescription = `Meet ${entry.data.name}, ${roleDescription} at The Blonding Room in Arva, near London, Ontario. Specializing in blonding, balayage, and colour services.`
---

<Layout
  title={entry.data.name}
  description={staffDescription}
  imageAlt={entry.data.image.alt}
  image={entry.data.image.src.src}
>
  <div class="bg-gray-900 py-16 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="mx-auto grid max-w-sm grid-cols-1 items-start gap-10 sm:max-w-none md:gap-16 lg:grid-cols-2"
      >
        <div>
          <div
            class="aspect-4/5 relative overflow-hidden rounded-sm"
          >
            <Image
              class="absolute inset-0 h-full w-full object-cover"
              transition:name={`staff-image-${entry.id}`}
              src={entry.data.image.src}
              alt={entry.data.image.alt}
            />
          </div>
        </div>
        <div class="flex flex-col">
          <p class="text-sm font-light uppercase tracking-[0.25em] text-primary-400">
            {entry.data.role}{entry.data.businessRole && ` & ${entry.data.businessRole}`}
          </p>
          <h1
            transition:name={`staff-name-${entry.id}`}
            class="mt-3 font-cursive text-5xl font-thin text-white sm:text-6xl lg:text-7xl"
          >
            {entry.data.name}
          </h1>
          <div class="mt-4 h-px w-16 bg-primary-600"></div>
          <div class="prose mt-8 max-w-xl text-base font-light leading-7 text-gray-300">
            <Content />
          </div>
          <div class="mt-10">
            <a
              href={entry.data.socials.instagram}
              class="group inline-flex items-center gap-2 text-primary-500 transition-colors hover:text-primary-400"
            >
              <Icon
                name="lucide:instagram"
                class="h-5 w-5"
              />
              <span class="text-sm tracking-wide group-hover:underline">
                {
                  entry.data.socials.instagram
                    .replace('https://www.instagram.com/', '')
                    .replace('/', '')
                }
              </span>
              <span class="sr-only">Instagram link for {entry.data.name}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
