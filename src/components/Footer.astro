---
import { Icon } from 'astro-icon/components'
import clientProfile from '~/data/client-profile.json'

const navLinks = [
  { label: 'Services', href: '/#hair-services' },
  { label: 'About', href: '/#about' },
  { label: 'Team', href: '/#profile-cards' },
  { label: 'Contact', href: '/#contact-us' },
]
---

<footer class="w-full border-t border-gray-800 bg-gray-950 py-12 md:py-16">
  <div class="container mx-auto flex flex-col items-center gap-8 px-4">
    <p class="font-cursive text-3xl text-white md:text-4xl">The Blonding Room</p>
    <p class="text-sm font-light tracking-wide text-gray-400">
      Where every shade tells a story
    </p>

    <nav class="flex flex-wrap justify-center gap-6 md:gap-8">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-xs font-medium uppercase tracking-[0.2em] text-gray-400 transition-colors hover:text-primary-400"
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="h-px w-16 bg-gray-800"></div>

    <a
      href={clientProfile.socialMedia.instagram}
      class="text-gray-400 transition-colors hover:text-primary-400"
    >
      <Icon name="lucide:instagram" class="h-5 w-5" />
      <span class="sr-only">Instagram</span>
    </a>

    <p class="text-xs text-gray-500">
      &copy; {new Date().getFullYear()} The Blonding Room. All rights reserved.
    </p>
  </div>
</footer>
