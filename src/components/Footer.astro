---
import { Icon } from 'astro-icon/components'
import clientProfile from '~/data/client-profile.json'
---

<footer class="w-full bg-black pb-4 pt-3 text-gray-400">
  <div
    class="container mx-auto flex max-w-xs flex-col-reverse items-center justify-between gap-4 md:max-w-lg md:flex-row md:gap-0 lg:max-w-xl"
  >
    <div>
      <p class="text-center text-xs md:text-sm">
        © {new Date().getFullYear()} The blonding room. All rights reserved
      </p>
    </div>
    <div>
      <ul>
        <li>
          <a
            href={clientProfile.socialMedia.instagram}
            class="group block rounded-sm bg-gray-900 p-1 hover:text-white/90 focus:text-white/90"
          >
            <Icon name="lucide:instagram" class="h-6 w-6" />
            <span class="sr-only">instagram</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
