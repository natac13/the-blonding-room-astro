---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { HAIR_SERVICES } from "../data/hair-services";
import Gallery from "./Gallery.astro";
import SectionHeader from "./SectionHeader.astro";
import heroBlonding from "../assets/gallery-2/hair/hair-1.jpg";
import heroColouring from "../assets/gallery-2/hair/hair-3.jpg";
import heroCuts from "../assets/gallery-2/hair/hair-5.jpg";

const galleryImages = Object.values(
  import.meta.glob<{ default: ImageMetadata }>(
    "../assets/gallery-2/hair/*.jpg",
    { eager: true },
  ),
).map((mod) => mod.default);

const categoryImages = [heroBlonding, heroColouring, heroCuts];
---

<section
  id="hair-services"
  class="bg-gray-900"
  aria-describedby="hair-services-title"
>
  <div
    class="mx-auto max-w-2xl px-4 py-20 sm:px-6 sm:py-32 lg:max-w-7xl lg:px-8"
  >
    <SectionHeader title="Hair Services" id="hair-services-title">
      <Fragment>
        <div class="mx-auto my-6 h-px w-24 bg-primary-500"></div>
        <p
          class="text-center text-sm font-light leading-6 text-gray-300 md:text-lg"
        >
          Pricing is personalized to each independent stylist.
          <br />All services include Olaplex (Bonding Agent).
        </p>
      </Fragment>
    </SectionHeader>

    <div class="container mt-12 space-y-16 md:mt-16 md:space-y-28">
      {
        HAIR_SERVICES.map((service, idx) => (
          <>
            <div class="flex w-full flex-col">
              <div
                class={`flex flex-col items-center gap-6 md:gap-12 lg:gap-16 ${
                  idx % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"
                }`}
              >
                <div class="flex w-full flex-col items-center gap-4 md:w-1/2">
                  <div class="aspect-3/4 w-full overflow-hidden rounded-sm">
                    <Image
                      src={categoryImages[idx]}
                      alt={`${service.title} services at The Blonding Room`}
                      class="h-full w-full object-cover"
                    />
                  </div>
                  <h3 class="text-center font-cursive text-3xl font-extralight text-white sm:text-4xl md:text-5xl lg:text-6xl">
                    {service.title}
                  </h3>
                </div>
                <div class="flex w-full flex-col gap-6 md:w-1/2 md:gap-8">
                  {service.items?.map((item) => (
                    <div class="flex flex-row items-start">
                      <div class="mr-3 mt-2.5 h-px w-5 shrink-0 bg-primary-500 md:mr-4 md:w-6" />
                      <div class="flex flex-col items-start gap-y-1.5">
                        <p class="text-sm font-medium uppercase tracking-widest text-white md:text-lg">
                          {item?.title}
                        </p>
                        {item?.description && (
                          <p class="text-sm font-light leading-6 text-gray-300 md:leading-7 lg:text-base">
                            {item.description}
                          </p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            {idx < HAIR_SERVICES.length - 1 && (
              <div class="mx-auto h-px w-24 bg-primary-600/50" />
            )}
          </>
        ))
      }
    </div>
  </div>
  <Gallery
    images={galleryImages}
    id="hair"
    context="Hair styling and colour at The Blonding Room"
  />
</section>
