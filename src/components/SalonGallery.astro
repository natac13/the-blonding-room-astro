---
import type { ImageMetadata } from 'astro'
import Gallery from './Gallery.astro'

const images = Object.values(
  import.meta.glob<{ default: ImageMetadata }>('../assets/gallery-2/salon/*.jpg', { eager: true }),
).map((mod) => mod.default)
---

<Gallery images={images} id="salon" context="Salon interior at The Blonding Room" />
