---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

type Props = {
  staff: CollectionEntry<'staff'>
}

const { staff } = Astro.props
---

<li class="w-full">
  <a href={`/staff/${staff.id}`} class="group block">
    <div class="aspect-4/5 relative overflow-hidden rounded-sm">
      <Image
        transition:name={`staff-image-${staff.id}`}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-in-out group-hover:scale-105"
        src={staff.data.image.src}
        alt={staff.data.image.alt}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
        <div class="absolute bottom-0 w-full p-4 md:p-5">
          <p class="text-sm font-light text-primary-300">
            {staff.data.role}
          </p>
        </div>
      </div>
    </div>
    <div class="mt-4">
      <h3
        transition:name={`staff-name-${staff.id}`}
        class="text-lg font-light text-white transition-colors duration-300 group-hover:text-primary-400 md:text-xl"
      >
        {staff.data.name}
      </h3>
      <p
        transition:name={`staff-role-${staff.id}`}
        class="mt-1 text-sm text-gray-400 md:text-base"
      >
        {staff.data.businessRole && `${staff.data.businessRole}`}
      </p>
      <div class="mt-3 w-8 border-b border-primary-600 transition-all duration-500 group-hover:w-16"></div>
    </div>
  </a>
</li>
