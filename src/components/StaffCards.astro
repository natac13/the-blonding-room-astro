---
import { getCollection } from 'astro:content'
import StaffCard from './StaffCard.astro'
import SectionHeader from './SectionHeader.astro'

const owners = await getCollection('staff', ({ data }) => {
  return data.businessRole?.toLowerCase()?.includes('owner')
}).then((owners) => {
  return owners.sort((a, b) => {
    return a.data.order - b.data.order
  })
})
const staff = await getCollection('staff', ({ data }) => {
  return !data.businessRole?.toLowerCase()?.includes('owner')
}).then((owners) => {
  return owners.sort((a, b) => {
    return a.data.order - b.data.order
  })
})
---

<section id="profile-cards" class="bg-gray-900 py-20 sm:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    <SectionHeader title="Our Team" id="team-title">
      <div class="mx-auto my-6 h-px w-24 bg-primary-500"></div>
    </SectionHeader>

    <ul
      id="owners"
      class="mx-auto mt-12 grid max-w-sm grid-cols-1 gap-8 sm:max-w-none sm:grid-cols-2 md:mt-16 md:gap-10 lg:gap-12"
    >
      {owners.map((owner) => <StaffCard staff={owner} />)}
    </ul>
    <ul
      id="staff"
      class="mx-auto mt-10 grid max-w-sm grid-cols-1 gap-8 sm:max-w-none sm:grid-cols-2 md:mt-12 md:gap-10 lg:grid-cols-3 lg:gap-12"
    >
      {staff.map((s) => <StaffCard staff={s} />)}
    </ul>
  </div>
</section>
