---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  images: ImageMetadata[]
  id?: string
}

const { images, id = Math.random().toString() } = Astro.props
---

<div class="container mx-auto my-20">
  <ul
    role="list"
    class:list={[
      'pswp-gallery grid grid-flow-row-dense grid-cols-2 max-w-[90rem] items-center mx-auto justify-center gap-x-4 gap-y-8 px-2 sm:grid-cols-3 sm:gap-x-6',
      images.length > 3 ? 'lg:grid-cols-4' : 'lg:max-w-6xl',
      images.length > 4 && '2xl:grid-cols-5',
    ]}
    id={`gallery-${id}`}
  >
    {
      images.map((image) => {
        return (
          <li class="relative">
            <a
              href={image.src}
              data-pswp-width={image.width}
              data-pswp-height={image.height}
              target="_blank"
              class="group aspect-4/5 block w-full overflow-hidden rounded-sm bg-gray-100 focus-within:ring-2 focus-within:ring-primary-500 focus-within:ring-offset-2 focus-within:ring-offset-gray-100"
            >
              <Image
                src={image}
                alt="image"
                class="h-full w-full object-cover group-hover:opacity-75"
              />
            </a>
          </li>
        )
      })
    }
  </ul>
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox'
  import 'photoswipe/style.css'

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.pswp-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  })
  lightbox.init()
</script>
