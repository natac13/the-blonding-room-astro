---
interface Props {
  title: string
  content: string
  href: string
}
const { title, content, href } = Astro.props
---

<a href={href} class="group flex flex-col items-center gap-3 text-center">
  <div class="text-primary-500">
    <slot />
  </div>
  <h4 class="text-xs font-medium uppercase tracking-[0.2em] text-gray-400">
    {title}
  </h4>
  <p class="text-sm font-light text-gray-200 transition-colors group-hover:text-primary-400 md:text-base">
    {content}
  </p>
</a>
