---
import { Image } from "astro:assets";
import heroImage from "~/assets/gallery-2/staff/group-0.jpg";
---

<section
  id="hero"
  class="relative flex min-h-[85vh] w-full items-center justify-center overflow-hidden bg-gray-950 lg:min-h-screen"
>
  <Image
    src={heroImage}
    alt="The Blonding Room team"
    loading="eager"
    class="absolute inset-0 h-full w-full object-cover opacity-40"
    widths={[640, 1024, 1440, 1920]}
    sizes="100vw"
  />
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/20 to-gray-900"
  >
  </div>
  <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
    <p
      class="mb-4 text-sm font-light uppercase tracking-[0.35em] text-primary-300"
    >
      Welcome to
    </p>
    <h1
      class="font-cursive text-6xl font-thin text-white md:text-7xl lg:text-8xl xl:text-9xl"
    >
      The Blonding Room
    </h1>
    <p
      class="mt-1 text-sm tracking-widest text-gray-400 uppercase lg:text-base"
    >
      Hair Salon in Arva, Near London, Ontario
    </p>
    <div class="mx-auto my-6 h-px w-24 bg-primary-500"></div>
    <h2
      class="text-lg font-extralight tracking-wide text-gray-200 md:text-xl lg:text-3xl"
    >
      <span class="font-medium">Blonding</span>,{" "}
      <span class="font-medium">Colouring</span> &{" "}
      <span class="font-medium">Styling</span> Services
    </h2>
    <p class="mt-3 text-base font-light text-gray-400 lg:text-lg">
      Are you ready to join us?
    </p>
    <div class="mt-10">
      <a
        href="/#contact-us"
        class="inline-block border border-primary-500 bg-primary-600 px-8 py-3 text-sm font-medium uppercase tracking-[0.2em] text-black transition-all duration-300 hover:bg-transparent hover:text-primary-400"
      >
        Book Now
      </a>
    </div>
  </div>
</section>
